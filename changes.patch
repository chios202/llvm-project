+  // Arithmetic operations without any multiplication
+  %add1 = arith.addf %x, %y : f32
+  %sub1 = arith.subf %add1, %z : f32
+  %add2 = arith.addf %sub1, %y : f32
+  %sub2 = arith.subf %add2, %x : f32
