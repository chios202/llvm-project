+#ifndef MLIR_TOOLS_MLIRQUERY_MATCHER_MATCHEDOPSET_H
+#define MLIR_TOOLS_MLIRQUERY_MATCHER_MATCHEDOPSET_H
+
+#include "mlir/IR/Operation.h"
+#include "llvm/ADT/ArrayRef.h"
+#include "llvm/ADT/SmallVector.h"
+#include "llvm/ADT/StringMap.h"
+
+namespace mlir::query::matcher {
+
+class BoundOperations {
+public:
+  void bind(llvm::StringRef id, llvm::ArrayRef<Operation *> ops) {
+    boundOperations[id] =
+        llvm::SmallVector<Operation *, 4>(ops.begin(), ops.end());
+  }
+
+private:
+  using BoundOperationsContainer =
+      llvm::StringMap<llvm::SmallVector<Operation *, 4>>;
+  BoundOperationsContainer boundOperations;
+};
+
+} // namespace mlir::query::matcher
